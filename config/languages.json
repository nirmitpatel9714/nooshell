    "args": ["-i", "-q"],
    "mode": "repl"
  },
  "js": {
    "cmd": "node",
    "args": ["-i"],
    "mode": "repl"
  },
  "ps": {
    "cmd": "powershell",
    "args": ["-NoLogo", "-NoExit", "-Command", "-"],
    "mode": "repl"
  },
  "bash": {
    "cmd": "bash",
    "args": [],
    "mode": "repl"
  },
  "cpp": {
    "cmd": "echo",
    "args": ["C++ REPL is not available; use clangd for highlighting"],
    "mode": "repl",
    "lsp": {
      "cmd": "clangd",
      "args": [],
      "language_id": "cpp"
    }
  }
}
