# =============================================================
# nooshell test.ns — comprehensive test of all features
# =============================================================
# Run:  noo test.ns          (interpreter mode)
# Compile & run:  noo compile test.ns    (compiled exe)
# =============================================================
# Each line runs in its own REPL process (concurrent).
# Each line must be fully self-contained (no cross-line state).

# ── 1. BASIC EXECUTION ──
py print("=== 1. BASIC EXECUTION ===")
py print("hello from python")
js console.log("hello from javascript")
ps Write-Host "hello from powershell"

# ── 2. PYTHON IF STATEMENTS ──
py print("\n=== 2. PYTHON IF STATEMENTS ===")
py score = 85; exec("if score > 50: print('PY: score > 50: PASS')")
py score = 85; exec("if score <= 50: print('PY: should not print')")
py name = "alice"; exec("if name == 'alice': print('PY: name is alice: PASS')")
py score = 85; threshold = 30; exec("if threshold < score: print('PY: threshold < score: PASS')")

# ── 3. JS IF STATEMENTS ──
py print("\n=== 3. JS IF STATEMENTS ===")
js var x = 50; if (x > 40) { console.log("JS: x > 40: PASS"); }
js var y = 92; if (y >= 90) { console.log("JS: y >= 90: PASS"); }
js var z = 92; if (z % 2 === 0) { console.log("JS: even check: PASS"); }
js var w = 92; var wl = w >= 50 ? "big" : "small"; console.log("JS: ternary =", wl)

# ── 4. JS NESTED IF ──
py print("\n=== 4. JS NESTED IF ===")
js var a = 10; var b = 20; if (a > 0) { if (b > a) { console.log("JS: nested if: PASS"); } }
js var c = 10; var d = 20; if (c > 0 && d > c) { console.log("JS: compound condition: PASS"); }

# ── 5. MANUAL del ──
py print("\n=== 5. MANUAL del ===")
py exec("val = 'will be deleted'; print('PY: before del:', val)")
del val
py exec("print('PY: val exists:', 'val' in dir())")

# ── 6. CONCURRENCY STRESS ──
py print("\n=== 6. CONCURRENT EXECUTION STRESS ===")
py import time; time.sleep(0.2); print("py: slept 0.2s")
js var start = Date.now(); while(Date.now() - start < 150){}; console.log("js: busy-waited 150ms")
ps Start-Sleep -Milliseconds 100; Write-Host "ps: slept 100ms"
py import time; time.sleep(0.1); print("py: slept 0.1s again")
js console.log("js: quick log, no wait")

# ── 7. LARGE STATE ──
py print("\n=== 7. LARGE STATE ===")
py exec("big_list = list(range(100)); big_dict = {str(i): i*2 for i in range(50)}; print('PY: big_list len =', len(big_list), 'big_dict keys =', len(big_dict))")

# ── 8. EDGE: EMPTY LINES / COMMENTS ──


# just a comment
py print("\n=== 8. EDGE: EMPTY LINES / COMMENTS ===")
py print("blank lines and comments above skipped correctly")

# ── 9. EDGE: del NONEXISTENT ──
py print("\n=== 9. del NONEXISTENT ===")
del nonexistent_var
py print("del nonexistent_var did not crash (no-op)")

# ── 10. STRING CONTENT (var names in strings) ──
py print("\n=== 10. STRING CONTENT WITH VAR NAMES ===")
py exec("x = 'x and y and z in string'; y = 7; z = 3.14; print('x + y + z =', x, y, z)")

# ── 11. MULTIPLE ASSIGNMENTS ──
py print("\n=== 11. MULTIPLE ASSIGNMENTS ===")
py exec("a = b = c = 1; print('a b c:', a, b, c)")

# ── 12. BUILD-UP + CLEAN ──
py print("\n=== 12. BUILD-UP + CLEAN ===")
py exec("accum = 0; exec('for i in range(10): accum += i'); print('accum =', accum)")

# ── 13. LOAD TEST: LARGE LIST ──
py print("\n=== 13. LOAD TEST: LARGE LIST ===")
py exec("load_data = list(range(10000)); load_sum = sum(load_data); print('PY: len =', len(load_data), 'sum =', load_sum)")

# ── 14. LOAD TEST: RAPID UPDATES ──
py print("\n=== 14. LOAD TEST: RAPID UPDATES ===")
py r = 9; print("PY: r =", r)

# ── 15. LOAD TEST: HEAVY LOOP ──
py print("\n=== 15. LOAD TEST: HEAVY LOOP ===")
py exec("total = 0; exec('for i in range(100000): total += i'); print('PY: sum(0..99999) =', total)")

# ── 16. SUMMARY ──
py print("\n=== 16. TEST SUMMARY ===")
py print("All tests executed.")
py print("If no crashes above, core features work.")
py print("Check compiled exe for auto-cleanup behavior.")
